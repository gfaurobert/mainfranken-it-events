# Supabase — Werte aus dem Supabase-Dashboard (Project Settings → API)
SUPABASE_URL=https://<dein-projekt-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # nur serverseitig, NIE ins Frontend
# Alternativ (bestehendes Setup): SUPABASE_SECRET_KEY

# Projekt-Referenz (Subdomain der SUPABASE_URL), z.B. abcdefgh
SUPABASE_PROJECT_REF=<dein-projekt-ref>

# Supabase MCP — Personal Access Token (Account → Access Tokens)
SUPABASE_ACCESS_TOKEN=<dein-personal-access-token>

# Ingest-LLM (OpenCode Go via LiteLLM, OpenAI-kompatibel)
OPENCODE_GO_KEY=<dein-opencode-go-key>
# Der /go/-Pfad ist entscheidend (Go-Subscription); /zen/v1 wäre Pay-as-you-go.
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
# Default in config.py, hier nur zur Doku/Override.
OPENCODE_GO_MODEL=deepseek-v4-flash

# API + MCP server (Fastify)
PORT=3789

# Outbound email (PAT delivery) — nodemailer + custom SMTP
# Use the same SMTP settings as Supabase Auth → SMTP Settings, or any provider.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<smtp-username>
SMTP_PASS=<smtp-password>
SMTP_FROM="Mainfranken IT-Events <noreply@yourdomain.com>"

# Per-email cooldown for register_user (seconds)
REGISTER_EMAIL_COOLDOWN_SECONDS=300
