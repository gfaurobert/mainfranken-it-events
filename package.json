{
  "name": "mainfranken-it-events",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "node --env-file=.env --import tsx --watch src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "test:watch": "vitest",
    "check:supabase": "node scripts/check-supabase-access.mjs",
    "smoke:mcp": "node --env-file=.env scripts/smoke-mcp.mjs",
    "demo": "pnpm dlx serve web/demo -p 3456",
    "pm2:dev": "pm2 start ecosystem.dev.config.cjs",
    "pm2:dev:stop": "pm2 delete ecosystem.dev.config.cjs",
    "pm2:dev:restart": "pm2 restart ecosystem.dev.config.cjs",
    "pm2:dev:logs": "pm2 logs",
    "pm2:dev:logs:register": "pm2 logs mainfranken-api-dev --raw | grep --line-buffered registration\\."
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@fastify/cors": "^11.2.0",
    "@modelcontextprotocol/node": "^2.0.0-alpha.2",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.8.5",
    "nodemailer": "^9.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "pg": "^8.22.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
